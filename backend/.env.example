# PostgreSQL — Docker em desafio-qa usa porta 5433 no PC (ver docker-compose.yml).
# Se usar Postgres instalado à parte, ajuste host/porta/utilizador/palavra-passe.
DATABASE_URL="postgresql://desafio:desafio@localhost:5433/desafio_qa?schema=public"

# Segredo para JWT (em produção use valor longo e aleatório)
JWT_SECRET="altere-este-segredo-em-producao"
